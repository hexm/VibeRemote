# ============================================================
# VibeRemote 手工部署配置模板
# 复制为 deploy.env 后修改真实值
# ============================================================

APP_NAME=viberemote
SERVICE_NAME=viberemote-server

APP_USER=root
APP_GROUP=root

APP_HOME=/opt/viberemote
BACKEND_DIR=/opt/viberemote/backend
FRONTEND_DIR=/opt/viberemote/frontend
LOG_DIR=/opt/viberemote/logs
TASK_LOG_STORAGE_PATH=/opt/viberemote/logs/tasks
RUN_DIR=/opt/viberemote/run

PORTAL_ROOT=/var/www/html
PORTAL_LISTEN_PORT=80
ADMIN_LISTEN_PORT=3000
API_PORT=8080
NGINX_SERVER_NAME=_
NGINX_CONFIG_FILE=/etc/nginx/conf.d/viberemote.conf
# NGINX_BIN=

PORTAL_PUBLIC_BASE_URL=http://your-server-ip
ADMIN_PUBLIC_BASE_URL=http://your-server-ip:3000
API_PUBLIC_BASE_URL=http://your-server-ip:8080
# 留空时默认自动推导为 ${PORTAL_PUBLIC_BASE_URL}/agent/release
AGENT_PACKAGE_BASE_URL=

DB_URL="jdbc:mysql://your-db-host:3306/viberemote?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&characterEncoding=utf8&autoReconnect=true&failOverReadOnly=false&maxReconnects=10"
DB_USERNAME=viberemote
DB_PASSWORD=change-me

# 留空时自动生成，并保存到 ${APP_HOME}/deploy-generated.env
JWT_SECRET=
REGISTER_TOKEN=replace-with-your-register-token
WEB_ENCRYPTION_KEY=replace-with-your-web-encryption-key

LOG_RETENTION_DAYS=90
MAX_UPLOAD_SIZE_MB=200
