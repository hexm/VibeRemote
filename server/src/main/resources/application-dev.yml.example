# ============================================================
# 开发环境配置模板
# 复制此文件为 application-dev.yml 并填写真实值
# ============================================================

spring:
  datasource:
    url: jdbc:mysql://${DB_HOST:your-db-host}:${DB_PORT:3306}/${DB_NAME:lightscript_dev}?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&characterEncoding=utf8&autoReconnect=true&failOverReadOnly=false&maxReconnects=10
    username: ${DB_USERNAME:your-db-username}
    password: ${DB_PASSWORD:your-db-password}
    driver-class-name: com.mysql.cj.jdbc.Driver
    hikari:
      maximum-pool-size: 5
      minimum-idle: 2
      connection-timeout: 20000
      idle-timeout: 300000
      max-lifetime: 1200000
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
  security:
    user:
      name: admin
      password: your-admin-password

logging:
  level:
    com.example.lightscript: DEBUG
    org.springframework.security: WARN
    org.hibernate.SQL: DEBUG
    org.hibernate.type.descriptor.sql.BasicBinder: WARN
  file:
    name: server/logs/server-dev.log

lightscript:
  jwt:
    secret: your-dev-jwt-secret-at-least-32-chars
  register:
    token: your-dev-register-token
  log:
    storage:
      path: logs/tasks
    retention:
      days: 30
